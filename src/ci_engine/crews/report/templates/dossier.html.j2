<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ doc_title }} — Competitive Intelligence Dossier</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
{%- macro cite(nums) -%}{%- if nums -%}<sup class="c">{{ nums|join(',') }}</sup>{%- endif -%}{%- endmacro -%}
<style>
  :root{
    --paper:#fbfbf8; --panel:#ffffff; --ink:#15201b; --muted:#5c6660; --faint:#8b948e;
    --line:#e3e4dd; --line-2:#cfd2c9;
    --accent:#167b32; --accent-d:#0d5121; --accent-soft:#e7f4ea;
    --rival:#bd4a1e; --rival-d:#7c2d12; --rival-soft:#f7e9e1;
    --pos:#2f7d32; --pos-soft:#e8f3e6; --neg:#b03030; --neg-soft:#f6e7e7;
    --opp:#1d6fa5; --opp-soft:#e6f0f8; --thr:#9a6a0b; --thr-soft:#f8efd9;
    --mono:'IBM Plex Mono',ui-monospace,Menlo,monospace;
    --disp:'Space Grotesk',system-ui,sans-serif;
    --body:'Inter',system-ui,-apple-system,'Segoe UI',sans-serif;
  }
  *{box-sizing:border-box}
  html{-webkit-text-size-adjust:100%}
  body{margin:0;background:var(--paper);color:var(--ink);font-family:var(--body);font-size:16px;line-height:1.65;font-weight:400;}
  .wrap{max-width:880px;margin:0 auto;padding:56px 28px 96px;}
  .eyebrow{font-family:var(--mono);font-size:12px;letter-spacing:.08em;text-transform:uppercase;color:var(--accent);font-weight:600;margin:0 0 10px;}
  h1{font-family:var(--disp);font-weight:700;font-size:38px;line-height:1.1;letter-spacing:-.01em;margin:0 0 14px;}
  h2{font-family:var(--disp);font-weight:600;font-size:25px;line-height:1.15;margin:56px 0 8px;letter-spacing:-.01em;}
  h3{font-family:var(--disp);font-weight:600;font-size:18px;margin:30px 0 6px;}
  h4{font-family:var(--mono);font-weight:600;font-size:13px;letter-spacing:.04em;text-transform:uppercase;color:var(--muted);margin:22px 0 6px;}
  p{margin:10px 0;} a{color:var(--accent);}
  .lead{font-size:18px;color:#33403a;}
  .sub{color:var(--muted);font-size:15px;}
  .rule{height:1px;background:var(--line);border:0;margin:14px 0 0;}
  sup.c{font-family:var(--mono);font-size:10px;color:var(--faint);font-weight:500;padding-left:1px;}
  .hdr-meta{display:flex;flex-wrap:wrap;gap:10px 22px;font-family:var(--mono);font-size:12.5px;color:var(--muted);margin-top:18px;}
  .hdr-meta b{color:var(--ink);font-weight:600;}
  .callout{background:var(--panel);border:1px solid var(--line-2);border-left:4px solid var(--accent);border-radius:8px;padding:22px 24px;margin:22px 0;}
  .callout h4{margin-top:0;}
  .note{background:#fcfaf3;border:1px solid var(--line);border-radius:8px;padding:16px 18px;font-size:14.5px;color:#46504a;margin:16px 0;}
  .note.warn{border-left:4px solid var(--thr);}
  .toc{font-family:var(--mono);font-size:13px;columns:2;column-gap:34px;margin:8px 0 0;color:var(--muted);}
  .toc a{color:var(--muted);text-decoration:none;display:block;padding:3px 0;}
  .toc a:hover{color:var(--accent);}
  table{width:100%;border-collapse:collapse;margin:16px 0;font-size:14px;}
  caption{caption-side:top;text-align:left;font-family:var(--mono);font-size:12px;text-transform:uppercase;letter-spacing:.05em;color:var(--faint);padding-bottom:8px;}
  th,td{text-align:left;padding:9px 11px;border-bottom:1px solid var(--line);vertical-align:top;}
  thead th{font-family:var(--mono);font-size:11.5px;letter-spacing:.03em;text-transform:uppercase;color:var(--muted);font-weight:600;border-bottom:1.5px solid var(--line-2);background:#f6f6f0;}
  tbody tr:nth-child(even){background:#faf9f4;}
  td.win-j{background:var(--accent-soft);} td.win-s{background:var(--rival-soft);}
  .readout td:first-child{font-family:var(--disp);font-weight:600;width:28%;color:var(--accent-d);}
  .tag{font-family:var(--mono);font-size:11px;font-weight:600;padding:1px 7px;border-radius:20px;display:inline-block;white-space:nowrap;}
  .tag.j{background:var(--accent-soft);color:var(--accent-d);} .tag.s{background:var(--rival-soft);color:var(--rival-d);}
  .assess{font-family:var(--mono);font-size:11px;font-weight:600;padding:2px 8px;border-radius:20px;white-space:nowrap;}
  .assess-jfrog_advantage{background:var(--accent-soft);color:var(--accent-d);}
  .assess-competitor_advantage{background:var(--rival-soft);color:var(--rival-d);}
  .assess-parity{background:#eef3f0;color:#4e6259;}
  .assess-unclear{background:var(--thr-soft);color:var(--thr);}
  .pill{font-family:var(--mono);font-size:11px;font-weight:600;padding:2px 9px;border-radius:4px;letter-spacing:.03em;text-transform:uppercase;white-space:nowrap;}
  .p-high{background:var(--neg-soft);color:var(--neg);} .p-moderate{background:var(--thr-soft);color:var(--thr);} .p-low{background:var(--pos-soft);color:var(--pos);}
  .pestel{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin:18px 0;}
  .pcell{background:var(--panel);border:1px solid var(--line);border-radius:8px;padding:14px 15px;}
  .pcell.dim{opacity:.62;}
  .pcell .k{font-family:var(--disp);font-weight:600;font-size:15px;color:var(--accent-d);margin:0 0 4px;}
  .pcell p{font-size:13px;margin:6px 0 0;color:#3c453f;line-height:1.5;}
  .pcell .f{font-family:var(--mono);font-size:11.5px;color:var(--muted);display:block;margin-top:8px;}
  .forces{margin:18px 0;}
  .force{display:grid;grid-template-columns:170px 96px 1fr;gap:14px;align-items:start;padding:12px 0;border-bottom:1px solid var(--line);}
  .force .name{font-family:var(--disp);font-weight:600;font-size:15px;}
  .force p{margin:0;font-size:13.5px;color:#3c453f;}
  .swot{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin:18px 0;}
  .q{border-radius:8px;padding:16px 18px;border:1px solid var(--line);}
  .q h4{margin:0 0 8px;font-size:13px;color:var(--ink);}
  .q ul{margin:0;padding-left:18px;} .q li{font-size:13.5px;margin:5px 0;color:#33403a;line-height:1.45;}
  .q.s{background:var(--pos-soft);border-color:#cfe5cd;} .q.s h4{color:#1f5f22;}
  .q.w{background:var(--neg-soft);border-color:#e9cdcd;} .q.w h4{color:#8a2727;}
  .q.o{background:var(--opp-soft);border-color:#cfe0ee;} .q.o h4{color:#185a87;}
  .q.t{background:var(--thr-soft);border-color:#ecdcb6;} .q.t h4{color:#7a5409;}
  figure{margin:18px 0;} figcaption{font-family:var(--mono);font-size:11.5px;color:var(--faint);text-align:center;margin-top:6px;}
  .posmap{width:100%;height:auto;display:block;background:var(--panel);border:1px solid var(--line);border-radius:8px;}
  .posmap .ax{stroke:#b7b9af;stroke-width:1;}
  .posmap .axl{font-family:var(--mono);font-size:11px;fill:var(--muted);}
  .posmap .lbl{font-family:var(--disp);font-size:13px;font-weight:600;fill:var(--ink);}
  .posmap .lblm{font-family:var(--body);font-size:12px;fill:var(--muted);}
  .scards{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin:18px 0;}
  .scard{border:1px solid var(--line);border-radius:8px;padding:15px 16px;background:var(--panel);}
  .scard .h{display:flex;justify-content:space-between;align-items:baseline;gap:10px;}
  .scard .v{font-family:var(--disp);font-weight:700;font-size:20px;color:var(--accent-d);}
  .bar{height:7px;border-radius:99px;background:#e7efe9;overflow:hidden;margin:9px 0;}
  .bar span{display:block;height:100%;background:var(--accent);border-radius:99px;}
  .scard p{font-size:13px;margin:7px 0 0;color:#3c453f;}
  .refs{font-size:12.5px;color:var(--muted);} .refs li{margin:6px 0;line-height:1.4;word-break:break-word;}
  .refs a{color:var(--accent);}
  .miss{font-family:var(--mono);font-size:12.5px;color:var(--thr);margin:8px 0;}
  @media (max-width:640px){
    .wrap{padding:36px 16px 64px;} h1{font-size:30px;}
    .pestel,.swot,.scards{grid-template-columns:1fr;} .force{grid-template-columns:1fr;gap:4px;} .toc{columns:1;}
    .readout td:first-child{width:auto;}
  }
  @media print{
    body{background:#fff;} .wrap{max-width:none;padding:0;}
    .callout,.q,.pcell,.note,.posmap,table,.scard{break-inside:avoid;} h2{break-after:avoid;}
  }
</style>
</head>
<body>
<div class="wrap">

  <p class="eyebrow">{{ doc_eyebrow }}</p>
  <h1>{{ doc_title }}</h1>
  <p class="lead">{{ doc_lead }}</p>
  <div class="hdr-meta">
    <span>{{ doc_meta_label }}: <b>{{ competitor }}</b></span>
    <span>Audience: <b>executive + technical</b></span>
    <span>Generated: <b>{{ generated_date }}</b></span>
  </div>
  <hr class="rule">

  {% if toc %}
  <h4>Contents</h4>
  <nav class="toc">
    {% for entry in toc %}<a href="#{{ entry.anchor }}">{{ entry.label }}</a>{% endfor %}
  </nav>
  {% endif %}

  {# ---------------- Executive summary ---------------- #}
  {% if show_executive %}
  <h2 id="executive-summary">Executive Summary</h2>
  {% if executive.thesis and executive.thesis.text %}
  <div class="callout">
    <p style="margin:0">{{ executive.thesis.text }}{{ cite(executive.thesis.cites) }}</p>
  </div>
  {% endif %}

  {% if executive.tradeoff_rows %}
  <table>
    <caption>Competitive tradeoff matrix</caption>
    <thead><tr><th>Lens</th><th>JFrog edge</th><th>{{ competitor }} edge / pressure</th><th>Implication</th></tr></thead>
    <tbody>
    {% for row in executive.tradeoff_rows %}
      <tr>
        <td><b>{{ row.lens }}</b></td>
        <td>{{ row.jfrog.text }}{{ cite(row.jfrog.cites) }}</td>
        <td>{{ row.competitor.text }}{{ cite(row.competitor.cites) }}</td>
        <td>{{ row.implication.text }}{{ cite(row.implication.cites) }}</td>
      </tr>
    {% endfor %}
    </tbody>
  </table>
  {% endif %}

  {% if executive.recommended_actions %}
  <h4>Recommended actions for JFrog</h4>
  <ul>
    {% for action in executive.recommended_actions %}<li>{{ action.text }}{{ cite(action.cites) }}</li>{% endfor %}
  </ul>
  {% endif %}

  {% if executive.swot %}
  <h3>SWOT — {{ executive.swot.vantage or competitor }}</h3>
  <div class="swot">
    <div class="q s"><h4>Strengths</h4><ul>{% for i in executive.swot.strengths %}<li>{{ i.text }}{{ cite(i.cites) }}</li>{% endfor %}</ul></div>
    <div class="q w"><h4>Weaknesses</h4><ul>{% for i in executive.swot.weaknesses %}<li>{{ i.text }}{{ cite(i.cites) }}</li>{% endfor %}</ul></div>
    <div class="q o"><h4>Opportunities</h4><ul>{% for i in executive.swot.opportunities %}<li>{{ i.text }}{{ cite(i.cites) }}</li>{% endfor %}</ul></div>
    <div class="q t"><h4>Threats</h4><ul>{% for i in executive.swot.threats %}<li>{{ i.text }}{{ cite(i.cites) }}</li>{% endfor %}</ul></div>
  </div>
  {% endif %}
  {% endif %}

  {# ---------------- Body sections ---------------- #}
  {% for section in sections %}
  <h2 id="{{ section.id|replace('_','-') }}">{{ section.title }}</h2>
  <p class="eyebrow" style="margin-top:-2px">{{ section.eyebrow }}</p>
  {% if section.lead and section.lead.text %}
  <p class="lead">{{ section.lead.text }}{{ cite(section.lead.cites) }}</p>
  {% endif %}

  {% if section.readouts %}
  <table class="readout">
    <tbody>
    {% for row in section.readouts %}
      <tr><td>{{ row.label }}</td><td>{{ row.text }}{{ cite(row.cites) }}</td></tr>
    {% endfor %}
    </tbody>
  </table>
  {% endif %}

  {% if section.pestel %}
  <h4>PESTEL — macro forces</h4>
  <div class="pestel">
    {% for cell in section.pestel %}
    <div class="pcell{% if not cell.material %} dim{% endif %}">
      <p class="k">{{ cell.axis }}</p>
      <p>{{ cell.factor }}</p>
      {% if cell.implication %}<span class="f">→ {{ cell.implication }}</span>{% endif %}
    </div>
    {% endfor %}
  </div>
  {% endif %}

  {% if section.five_forces %}
  <h4>Porter's Five Forces — industry structure</h4>
  <div class="forces">
    {% for force in section.five_forces %}
    <div class="force">
      <span class="name">{{ force.force }}</span>
      <span class="pill p-{{ force.intensity }}">{{ force.intensity }}</span>
      <p>{{ force.rationale }}</p>
    </div>
    {% endfor %}
  </div>
  {% endif %}

  {% if section.positioning %}
  {% set pm = section.positioning %}
  <h4>Strategic-group positioning map</h4>
  <figure>
    <svg class="posmap" viewBox="0 0 680 540" role="img" aria-label="Strategic-group positioning map">
      <line class="ax" x1="340" y1="500" x2="340" y2="60"/>
      <line class="ax" x1="70" y1="280" x2="610" y2="280"/>
      <text class="axl" x="340" y="48" text-anchor="middle">{{ pm.y_high_label }}</text>
      <text class="axl" x="340" y="520" text-anchor="middle">{{ pm.y_low_label }}</text>
      <text class="axl" x="74" y="300" text-anchor="start">{{ pm.x_low_label }}</text>
      <text class="axl" x="606" y="300" text-anchor="end">{{ pm.x_high_label }}</text>
      {% for p in pm.players %}
      {% set cx = 70 + (p.x / 100.0) * 540 %}
      {% set cy = 500 - (p.y / 100.0) * 440 %}
      <circle cx="{{ cx|round(1) }}" cy="{{ cy|round(1) }}" r="{{ 10 if p.is_focus else 7 }}"
        fill="{{ '#167b32' if p.is_focus and p.name|lower == 'jfrog' else ('#bd4a1e' if p.is_focus else '#c9c7bd') }}"
        stroke="{{ '#0d5121' if p.is_focus and p.name|lower == 'jfrog' else ('#7c2d12' if p.is_focus else '#8a887f') }}" stroke-width="1"/>
      <text class="{{ 'lbl' if p.is_focus else 'lblm' }}" x="{{ (cx + 14)|round(1) }}" y="{{ (cy + 4)|round(1) }}">{{ p.name }}</text>
      {% endfor %}
    </svg>
    <figcaption>Axes are an analytical judgment, not measured data.</figcaption>
  </figure>
  {% if pm.narrative %}<p>{{ pm.narrative }}</p>{% endif %}
  {% endif %}

  {% if section.capability_matrix %}
  <h4>Capability comparison</h4>
  <table>
    <thead><tr><th>Capability</th><th>JFrog</th><th>{{ competitor }}</th><th>Read</th></tr></thead>
    <tbody>
    {% for row in section.capability_matrix %}
      <tr>
        <td><b>{{ row.capability }}</b></td>
        <td>{{ row.jfrog }}</td>
        <td>{{ row.competitor }}</td>
        <td><span class="assess assess-{{ row.assessment }}">{{ row.assessment|replace('_',' ') }}</span></td>
      </tr>
    {% endfor %}
    </tbody>
  </table>
  {% endif %}

  {% if section.product_catalog %}
  <h4>Product catalog</h4>
  <table>
    <thead><tr><th>Vendor</th><th>Product</th><th>Category</th><th>Primary role</th><th>Capabilities</th></tr></thead>
    <tbody>
    {% for row in section.product_catalog %}
      <tr><td>{{ row.company }}</td><td>{{ row.product_name }}</td><td>{{ row.category }}</td><td>{{ row.primary_role }}</td><td>{{ row.capabilities }}</td></tr>
    {% endfor %}
    </tbody>
  </table>
  {% endif %}

  {% if section.capability_gaps %}
  <h4>Unresolved evidence gaps</h4>
  <table>
    <thead><tr><th>Capability</th><th>JFrog</th><th>{{ competitor }}</th><th>Readout</th></tr></thead>
    <tbody>
    {% for row in section.capability_gaps %}
      <tr><td>{{ row.capability }}</td><td>{{ row.jfrog_status }}</td><td>{{ row.competitor_status }}</td><td>{{ row.readout }}</td></tr>
    {% endfor %}
    </tbody>
  </table>
  {% endif %}

  {% for note in section.missing %}<p class="miss">{{ note }}</p>{% endfor %}
  {% endfor %}

  {# ---------------- Weighted scorecards ---------------- #}
  {% if scorecards %}
  <h2 id="scorecards">Weighted Buyer Scorecards</h2>
  <p class="sub">Scored 1–5 on the merits; weights reflect buyer archetypes. Who wins depends on what the buyer weights.</p>
  <div class="scards">
    {% for s in scorecards %}
    <div class="scard">
      <div class="h"><h3 style="margin:0">{{ s.company }} · {{ s.category }}</h3><span class="v">{{ s.value }}/{{ s.max_value }}</span></div>
      <p class="sub" style="margin-top:4px">{% if s.buyer_archetype %}{{ s.buyer_archetype }}{% endif %}{% if s.weight %} · Weight {{ s.weight }}%{% endif %}</p>
      <div class="bar"><span style="width: {{ s.percent }}%"></span></div>
      <p>{{ s.rationale }}{{ cite(s.cites) }}</p>
    </div>
    {% endfor %}
  </div>
  {% endif %}

  {# ---------------- Methodology & confidence ---------------- #}
  {% if confidence_tiering %}
  <h2 id="methodology">Methodology &amp; confidence</h2>
  <div class="note warn">
    {% for tier in confidence_tiering.tiers %}
    <p{% if loop.first %} style="margin-top:0"{% endif %}><b>{{ tier.label }}.</b> {{ tier.summary }}</p>
    {% endfor %}
    {% if confidence_tiering.spot_check %}
    <p style="margin-bottom:0"><b>Spot-check before exec review:</b> {{ confidence_tiering.spot_check|join(' ') }}</p>
    {% endif %}
  </div>
  {% endif %}

  {# ---------------- References ---------------- #}
  {% if references %}
  <h2 id="references">References</h2>
  <ol class="refs">
    {% for ref in references %}
    <li value="{{ ref.number }}">{{ ref.citation }}{% if ref.publisher %} — {{ ref.publisher }}{% endif %}{% if ref.date %} ({{ ref.date }}){% endif %}{% if ref.url %} · <a href="{{ ref.url }}">link</a>{% endif %}</li>
    {% endfor %}
  </ol>
  {% endif %}

</div>
</body>
</html>
